{
  "name": "@jr200-labs/xstate-duckdb",
  "version": "1.2.0",
  "description": "XState machine for DuckDB",
  "license": "MIT",
  "author": "Jayshan Raghunandan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jr200-labs/xstate-duckdb.git"
  },
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "prettier": "prettier --write \"**/*.{ts,mjs,js,json,md,yml,yaml}\"",
    "lint": "tsc --noEmit && eslint \"src/**/*.{ts,tsx}\"",
    "prepare": "husky",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "keywords": [
    "xstate",
    "duckdb",
    "duckdb-wasm",
    "state-machine"
  ],
  "dependencies": {
    "duckdb-wasm-kit": "^0.1.39",
    "pako": "^2.1.0",
    "xstate": "^5.32.0"
  },
  "peerDependencies": {
    "@duckdb/duckdb-wasm": ">=1.33.1-dev42.0 <2",
    "@opentelemetry/api": "^1.9.1",
    "apache-arrow": ">=21 <22"
  },
  "devDependencies": {
    "@apache-arrow/ts": "^21.1.0",
    "@duckdb/duckdb-wasm": "^1.33.1-dev42.0",
    "@eslint/js": "^10.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.7.1",
    "@opentelemetry/core": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@statelyai/inspect": "^0.7.1",
    "@types/pako": "^2.0.4",
    "@vitest/coverage-v8": "^4.1.8",
    "apache-arrow": "^21.1.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "syncpack": "^15.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
